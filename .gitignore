# ═══════════════════════════════════════════
# FRONTEND – Quasar / Node
# ═══════════════════════════════════════════
frontend/node_modules/
frontend/.quasar/
frontend/dist/
# Local env overrides – the built SPA already has public keys baked in
frontend/.env.local
frontend/.env.*.local

# ═══════════════════════════════════════════
# BACKEND – Symfony / PHP
# ═══════════════════════════════════════════

# Composer dependencies
backend/vendor/

# Symfony generated files
backend/var/

# Built bundles
backend/public/bundles/

# Uploaded files / user content (regenerated at runtime)
backend/public/uploads/

# The built Quasar SPA is intentionally committed so the server
# doesn't need Node.js.  Do NOT add backend/public/app/ here.

# Environment overrides – NEVER commit secrets
backend/.env.local
backend/.env.local.php
backend/.env.*.local
backend/config/secrets/prod/prod.decrypt.private.php

# PHPUnit
backend/.phpunit.cache/
backend/phpunit.xml

# Symfony asset-mapper compiled assets
backend/public/assets/
backend/assets/vendor/

# ═══════════════════════════════════════════
# DOCKER
# ═══════════════════════════════════════════
docker-compose.override.yml
.env.docker.local
