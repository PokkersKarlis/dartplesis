<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing files and directories directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Proxy /api/* requests to the backend (adjust ProxyPass in your VirtualHost instead)
  # RewriteRule ^api/(.*)$ http://backend:80/api/$1 [P,L]

  # Fallback: all other requests → index.html (SPA history mode)
  RewriteRule ^ index.html [L]
</IfModule>
