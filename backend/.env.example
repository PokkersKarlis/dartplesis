###############################################################
# Copy this file to  .env.local  on the server and fill in
# the real values.  Never commit .env.local to git.
###############################################################

# ── Symfony ────────────────────────────────────────────────
APP_ENV=prod
# Generate with: php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=CHANGE_ME_32_CHAR_HEX_STRING

# ── Database ───────────────────────────────────────────────
# Shared hosting: use the MySQL credentials from cPanel / Plesk
DATABASE_URL="mysql://DB_USER:DB_PASS@localhost:3306/DB_NAME?serverVersion=8.0.32&charset=utf8mb4"

# ── hCaptcha ───────────────────────────────────────────────
# Get your secret key from https://dashboard.hcaptcha.com/
HCAPTCHA_SECRET=CHANGE_ME_HCAPTCHA_SECRET

# ── CORS ───────────────────────────────────────────────────
# Replace with your actual domain (regex, anchored)
CORS_ALLOW_ORIGIN='^https?://yourdomain\.com$'

# ── Mailer (optional) ──────────────────────────────────────
MAILER_DSN=null://null
